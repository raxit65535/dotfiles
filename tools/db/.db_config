#!/bin/sh

# Database connection helper functions

# ============================================================================================================
# PostgreSQL connection Configuration
# ============================================================================================================

# local postgres connection
local_db() {
    local url ="postgres://pguser:pgpass@localhost:9001/postgres"
    psql "$url"
}

# Remote Database connection functions
# Example usage: remote_database_connection prd pgcli
# Extend this function to include more remote databases as needed

_pg_args () {
    DB_ENV=${1:-stg}
    DB_CLIENT=${2:-psql}
}


# cached token for 55 min
_pg_token() {
  local cache="/tmp/.pg_iam_token"
  local max_age=3300

  if [[ -f "$cache" ]]; then
    local age=$(( $(date +%s) - $(stat -f %m "$cache") ))
    if [[ "$age" -lt "$max_age" ]]; then
      cat "$cache"
      return
    fi
  fi

  local token
  token="$(gcloud sql generate-login-token)" || return 1
  printf '%s' "$token" > "$cache"
  printf '%s' "$token"
}

# Base connection function
_pg_connect() {
    local host=$1
    local dbname=$2
    local token="$(_pg_token)"
    local iam_user="${IAM_DB_USER}"
    local url="postgres://${iam_user}:${token}@${host}:5432/${dbname}"

    case $DB_CLIENT in
        psql)
            psql "$url"
            ;;
        usql)
            usql "$url"
            ;;
        *)
            echo "Unknown client: $DB_CLIENT. Supported: pgcli, psql, usql"
            return 1
            ;;
    esac
}


# ============================================================================================================
# CBT CLI connection Configuration for Google Cloud Bigtable
# ============================================================================================================

local_cbt() {
  cbt -project local-project -instance local-instance "$@"
}

# Connect to remote bigtable instance
remote_bt_connection() {
  cbt -project bigtable-project-id -instance bigtable-instance-id "$@"
}

# JSON formatter for piping
cbt-json() {
  grep { | jq -c '. | fromjson' | jq
}

# ============================================================================================================
# ClickHouse Connection Configuration
# ============================================================================================================

# Simple ClickHouse terminal connectors (HTTP/HTTPS via clickhouse-cli)
clickhouse_local() {
  usql "clickhouse://default@localhost:8123/default"
}

# ============================================================================================================
# DuckDB Connection Configuration
# ============================================================================================================

duck_local () {
  local mode="${1:-duckdb}"

  mkdir -p /tmp/duckdb
  local db="/tmp/duckdb/local.duckdb"
  local dsn="duckdb:///tmp/duckdb_local.db"

  # Run setup once before opening an interactive session (works for both tools)
  # Note: CREATE SECRET is idempotent with OR REPLACE.
  local setup_sql="INSTALL gcs FROM community;
      LOAD gcs;
      CREATE OR REPLACE SECRET gcs_adc (
        TYPE gcp,
        PROVIDER credential_chain
      );
    "

  if [[ "$mode" == "duckdb" ]]; then
    duckdb "$db" -cmd "$setup_sql"
    duckdb "$db"
  else
    usql "$dsn" -c "$setup_sql" >/dev/null
    usql "$dsn"
  fi
}


