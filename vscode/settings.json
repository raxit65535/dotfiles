{
  // =========================================================
  //                      TELEMETRY
  // =========================================================
  "telemetry.telemetryLevel": "off",
  // =========================================================
  //                WORKSPACE SAFETY (PRO DEFAULT)
  // =========================================================
  "security.workspace.trust.untrustedFiles": "open",
  // =========================================================
  //                    AI - Copilot
  // =========================================================
  // In VS Code settings.json — pick one:
  // Option A: Use Copilot for inline, Continue for chat
  "continue.enableTabAutocomplete": true,

  // Option B: Use Continue for inline, disable Copilot inline
  // "github.copilot.enable": { "*": false },
  // =========================================================
  //                    EDITOR (GLOBAL)
  // =========================================================
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  // Deterministic save actions
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.linkedEditing": true,
  "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.goToImplementation",
  "editor.gotoLocation.alternativeTypeDefinitionCommand": "editor.action.goToImplementation",
  "editor.fontSize": 13,
  "window.zoomLevel": 1,
  "editor.lineHeight": 2,
  "editor.mouseWheelZoom": false,
  "editor.trimAutoWhitespace": true,
  "editor.wordWrap": "off",
  "workbench.colorCustomizations": {
    "[Dark Modern]": {
      "terminal.background": "#1F1F1F",
      "panel.background": "#1F1F1F"
    },
    "[Dark 2026]": {
      // --- Existing Background Overrides ---
      "editor.background": "#1F1F1F",
      // "terminal.background": "#1F1F1F",
      // "panel.background": "#1F1F1F",

      "breadcrumb.background": "#1F1F1F",
      "panelStickyScroll.background": "#1F1F1F",
      "editorStickyScroll.background": "#1F1F1F",

      // --- Fixing the Gutter & Line Numbers ---
      "editorGutter.background": "#1F1F1F", // Matches the line number area to editor

      // --- Fixing File Tabs ---
      "tab.activeBackground": "#1F1F1F", // Active tab matches editor
      "tab.inactiveBackground": "#1F1F1F" // Inactive tabs match editor
    }
  },
  "editor.tokenColorCustomizations": {
    "[Dark Modern]": {
      "variables": "#88C0D0" // sage-mint color for all variables
    },
    "[Dark 2026]": {
      "functions": "#DCDCAA"
    }
  },
  // =========================================================
  //                         WORKBENCH
  // =========================================================
  "workbench.editor.enablePreview": false,
  "workbench.tree.indent": 15,
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.cursorWidth": 2,
  "editor.semanticHighlighting.enabled": false,
  "terminal.integrated.defaultLocation": "editor",
  // =========================================================
  //                         FILES
  // =========================================================
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",
  "explorer.autoReveal": true,
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  // =========================================================
  //              EXCLUDES (PERF + SIGNAL/NOISE)
  // =========================================================
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.idea": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.venv": true,
    "**/venv": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/tags": true,
    "**/tmp": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/.idea": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/*.log": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.venv/**": true
  },
  // =========================================================
  //                         GIT (BUILT-IN)
  // =========================================================
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "git.pruneOnFetch": true,
  // Built-in Git blame
  "git.blame.statusBarItem.enabled": true,
  "git.blame.editorDecoration.enabled": false,
  "git.blame.ignoreWhitespace": true,
  // =========================================================
  //                         GOLANG
  // =========================================================
  "go.enableCodeLens": {
    "runtest": true
  },
  "go.lintOnSave": "file",
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "go.coverOnTestPackage": false,
  "go.toolsManagement.autoUpdate": true,
  "[go]": {
    "editor.snippetSuggestions": "none",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "golang.go"
  },
  "gopls": {
    "staticcheck": true,
    "usePlaceholders": true,
    "completeUnimported": true,
    "deepCompletion": true,
    "formatting.gofumpt": true,
    "analyses": {
      "ST1003": false, // Don't complain about mixed caps in test function names
      "ST1005": false, // Don't complain about error strings not being lowercase
      "ST1000": false // Don't complain about package comments not being in the right format
    }
  },
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "jupyter.askForKernelRestart": false,
  "jupyter.interactiveWindow.creationMode": "perFile",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.completeFunctionParens": true,
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.nosetestsEnabled": false,
  "python.testing.autoTestDiscoverOnSaveEnabled": true,
  "ruff.enable": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    },
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll.ruff": "explicit",
    "notebook.source.organizeImports.ruff": "explicit"
  },
  "[requirements]": {
    "editor.formatOnSave": false
  },
  // =========================================================
  //                     MARKDOWN (BLOGGING)
  // =========================================================
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on"
  },
  "prettier.proseWrap": "always",
  "prettier.printWidth": 80,
  "markdownlint.run": "onSave",
  "markdownlint.config": {
    "MD013": false,
    "MD033": false
  },
  // =========================================================
  //                     SQL Formatting
  // =========================================================
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter",
    "editor.formatOnSave": false
  },
  "sql-formatter.dialect": "sql",
  "sql-formatter.uppercase": true,
  // =========================================================
  //               REACT / TYPESCRIPT (ENABLED)
  // =========================================================
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  // =========================================================
  //                        RUST
  // =========================================================
  "rust-analyzer.check.command": "clippy",
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "githubPullRequests.pullBranch": "never",
  "chat.viewSessions.orientation": "stacked",
  "python.createEnvironment.trigger": "off",
  "terminal.integrated.fontFamily": "monospace",
  "update.mode": "manual",
  "editor.minimap.enabled": false,
  "workbench.iconTheme": "material-icon-theme"
}
