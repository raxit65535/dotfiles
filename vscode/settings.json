{
  // =========================================================
  //                      TELEMETRY
  // =========================================================
  "telemetry.telemetryLevel": "off",

  // =========================================================
  //                WORKSPACE SAFETY (PRO DEFAULT)
  // =========================================================
  "security.workspace.trust.untrustedFiles": "open",

  // =========================================================
  //                    EDITOR (GLOBAL)
  // =========================================================
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  // Deterministic save actions
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "editor.inlineSuggest.enabled": true,
  "editor.suggestSelection": "first",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.linkedEditing": true,
  "editor.gotoLocation.alternativeDefinitionCommand": "editor.action.goToImplementation",
  "editor.gotoLocation.alternativeTypeDefinitionCommand": "editor.action.goToImplementation",
  "editor.fontSize": 13,
  "window.zoomLevel": 1,
  "editor.lineHeight": 2,
  "editor.mouseWheelZoom": false,
  "editor.trimAutoWhitespace": true,
  "editor.wordWrap": "off",
  "workbench.colorCustomizations": {
    "[Dark Modern]": {
      "terminal.background": "#1F1F1F",
      "panel.background": "#1F1F1F"
    },
    "[Dark 2026]": {
      // --- Existing Background Overrides ---
      "editor.background": "#1F1F1F",
      // "terminal.background": "#1F1F1F",
      // "panel.background": "#1F1F1F",

      "breadcrumb.background": "#1F1F1F",
      "panelStickyScroll.background": "#1F1F1F",
      "editorStickyScroll.background": "#1F1F1F",

      // --- Fixing the Gutter & Line Numbers ---
      "editorGutter.background": "#1F1F1F", // Matches the line number area to editor

      // --- Fixing File Tabs ---
      "tab.activeBackground": "#1F1F1F", // Active tab matches editor
      "tab.inactiveBackground": "#1F1F1F" // Inactive tabs match editor
    }
  },
  "editor.tokenColorCustomizations": {
    "[Dark Modern]": {
      "variables": "#88C0D0" // sage-mint color for all variables
    },
    "[Dark 2026]": {
      "functions": "#DCDCAA"
    }
  },

  // =========================================================
  //                         WORKBENCH
  // =========================================================
  "workbench.editor.enablePreview": false,
  "workbench.tree.indent": 15,
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.cursorWidth": 2,
  "editor.semanticHighlighting.enabled": false,
  "terminal.integrated.fontFamily": "monospace",
  "update.mode": "manual",
  "editor.minimap.enabled": false,

  // =========================================================
  //                         FILES
  // =========================================================
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",
  "explorer.autoReveal": true,
  "explorer.confirmDelete": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,

  // =========================================================
  //              EXCLUDES (PERF + SIGNAL/NOISE)
  // =========================================================
  "files.exclude": {
    "**/.DS_Store": true,
    "**/.git": true,
    "**/.idea": true,
    "**/__pycache__": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.venv": true,
    "**/venv": true,
    "**/*.pyc": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/tags": true,
    "**/tmp": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/.idea": true,
    "**/__pycache__": true,
    "**/.venv": true,
    "**/venv": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/build": true,
    "**/*.log": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.venv/**": true
  },

  // =========================================================
  //                         GIT (BUILT-IN)
  // =========================================================
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "always",
  "git.pruneOnFetch": true,
  // Built-in Git blame
  "git.blame.statusBarItem.enabled": true,
  "git.blame.editorDecoration.enabled": false,
  "git.blame.ignoreWhitespace": true,
  "githubPullRequests.pullBranch": "never",

  // =========================================================
  //                         GOLANG
  // =========================================================
  "go.enableCodeLens": {
    "runtest": true
  },
  "go.lintOnSave": "file",
  "go.lintTool": "golangci-lint",
  "go.lintFlags": ["--fast"],
  "go.coverOnTestPackage": false,
  "go.toolsManagement.autoUpdate": true,
  "[go]": {
    "editor.snippetSuggestions": "none",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
    "editor.defaultFormatter": "golang.go"
  },
  "gopls": {
    "staticcheck": true,
    "usePlaceholders": true,
    "completeUnimported": true,
    "deepCompletion": true,
    "formatting.gofumpt": true,
    "analyses": {
      "ST1003": false, // Don't complain about mixed caps in test function names
      "ST1005": false, // Don't complain about error strings not being lowercase
      "ST1000": false // Don't complain about package comments not being in the right format
    }
  },

  // =========================================================
  //                         PYTHON
  // =========================================================
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.createEnvironment.trigger": "off",

  // --- Pylance / type analysis ---
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.indexing": true,
  "python.analysis.userFileIndexingLimit": 2000,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.useLibraryCodeForTypes": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.completeFunctionParens": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": false,
  "python.analysis.exclude": [
    "**/.*",
    "**/node_modules",
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/.git",
    "**/.mypy_cache",
    "**/.pytest_cache",
    "**/.ruff_cache",
    "**/build",
    "**/dist"
  ],
  "python.analysis.diagnosticSeverityOverrides": {
    "reportMissingTypeStubs": "none",
    "reportPrivateImportUsage": "none"
  },

  // --- Testing ---
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["-v"],
  "python.testing.autoTestDiscoverOnSaveEnabled": true,

  // --- Ruff (formatting + linting) ---
  "ruff.enable": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    },
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },
  "[requirements]": {
    "editor.formatOnSave": false
  },

  // --- Jupyter / notebooks ---
  "jupyter.askForKernelRestart": false,
  "jupyter.interactiveWindow.creationMode": "perFile",
  "jupyter.notebookFileRoot": "${workspaceFolder}",
  "jupyter.enableExtendedKernelCompletions": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "notebook.source.fixAll.ruff": "explicit",
    "notebook.source.organizeImports.ruff": "explicit"
  },

  // =========================================================
  //                     MARKDOWN (BLOGGING)
  // =========================================================
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.wordWrap": "on",
    "preview.fontSize": 14,
    "preview.lineHeight": 1.6,
    "preview.scrollPreviewWithEditor": true,
    "preview.scrollEditorWithPreview": true,
    "preview.markEditorSelection": true
  },
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor"
  },

  "prettier.proseWrap": "always",
  "prettier.printWidth": 80,
  "markdownlint.run": "onSave",
  "markdownlint.config": {
    "MD013": false,
    "MD033": false
  },

  // JSON formatting
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // =========================================================
  //                     SQL Formatting
  // =========================================================
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter",
    "editor.formatOnSave": false
  },
  "sql-formatter.dialect": "sql",
  "sql-formatter.uppercase": true,

  // =========================================================
  //                     JAVASCRIPT / TYPESCRIPT
  // =========================================================
  // formatting
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },

  // settings
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.preferences.importModuleSpecifier": "non-relative",
  "typescript.suggest.completeFunctionCalls": true,
  "javascript.suggest.completeFunctionCalls": true,
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterTypes.enabled": false,
  "typescript.inlayHints.variableTypes.enabled": false,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "eslint.run": "onType",
  "eslint.format.enable": false,
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.useFlatConfig": true,
  "npm.packageManager": "auto",
  "debug.javascript.autoAttachFilter": "smart",
  "debug.node.autoAttach": "on",

  // =========================================================
  //                        RUST
  // =========================================================
  "[rust]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.tabSize": 4
  },
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.allTargets": true,
  "rust-analyzer.cargo.features": "all",
  "rust-analyzer.imports.granularity.group": "module",
  "rust-analyzer.imports.prefix": "crate",
  "rust-analyzer.inlayHints.bindingModeHints.enable": false,
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.closingBraceHints.minLines": 25,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.inlayHints.lifetimeElisionHints.enable": "skip_trivial",
  "rust-analyzer.lens.references.method.enable": true,
  "rust-analyzer.lens.implementations.enable": true,
  "rust-analyzer.completion.callable.snippets": "fill_arguments",
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.diagnostics.experimental.enable": false,

  // =========================================================
  //                        C/C++
  // =========================================================
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "clangd.arguments": [
    "--background-index",
    "--clang-tidy",
    "--header-insertion=iwyu",
    "--completion-style=detailed",
    "--function-arg-placeholders",
    "--pch-storage=memory",
    "--log=error"
  ],
  "clangd.checkUpdates": true,
  "clangd.onConfigChanged": "restart",
  "C_Cpp.intelliSenseEngine": "disabled",
  "cmake.configureOnOpen": true,
  "cmake.buildDirectory": "${workspaceFolder}/build",
  "cmake.exportCompileCommandsFile": true,
  "cmake.copyCompileCommands": "${workspaceFolder}/compile_commands.json",

  /*
    Add ~/.config/clangd/config.yaml
    CompileFlags:
      Add:
        - -std=c++20
        - -Wall
        - -Wextra
    Diagnostics:
      ClangTidy:
        Add:
          - modernize-*
          - performance-*
          - readability-*
        Remove:
          - modernize-use-trailing-return-type
          - readability-magic-numbers
          - readability-identifier-length
  */

  // =========================================================
  //                    AI - Copilot
  // =========================================================
  "github.copilot.enable": {
    "*": true
  },

  // Instructions: AGENTS.md or any *.instructions.md files
  "chat.instructionsFilesLocations": {
    "~/.vs-agents": true
  },

  // Skills (folders containing SKILL.md)
  "chat.agentSkillsLocations": {
    "~/.vs-agents/skills": true
  },

  // Custom agents (*.agent.md files)
  "chat.agentFilesLocations": {
    "~/.vs-agents/agents": true
  },

  // Enable the various features
  "chat.useAgentSkills": true,
  "chat.useHooks": true,
  "chat.mcp.discovery.enabled": {},
  "chat.math.enabled": false,
  "chat.tools.terminal.autoApprove": {
    "cp": true,
    "go": true,
    "gofmt": true,
    "docker-compose": true
  },
  "chat.agent.maxRequests": 500,
  "application.shellEnvironmentResolutionTimeout": 50,
  "chat.viewSessions.orientation": "stacked",
  "workbench.colorTheme": "Kanagawa Dragon",
  "workbench.iconTheme": "material-icon-theme"
}
